<div class="graph-controls" role="region" aria-labelledby="graph-controls-heading">
  <h2 id="graph-controls-heading" class="visually-hidden">Graph Controls</h2>

  <button type="button" id="reset-graph" class="btn-reset" aria-label="Reset graph view and clear all filters">
    Reset View
  </button>

  <div class="graph-instructions">
    <details>
      <summary>How to use</summary>
      <ul>
        <li>Hover over posts (circles) to see titles</li>
        <li>Click posts to read them</li>
        <li>Click tags (rectangles) to filter posts</li>
        <li>Use Reset View to show all posts</li>
      </ul>
    </details>
  </div>
</div>