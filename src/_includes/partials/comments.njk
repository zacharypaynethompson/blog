<section class="comments-section" aria-label="Comments">
  <h2 class="comments-heading">Comments</h2>

  <div class="giscus-container">
    <div class="giscus"></div>
  </div>

  <script>
    (function() {
      var pathPrefix = '{{ "/" | url }}';
      var isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
      var themeBase = window.location.origin + pathPrefix + 'assets/css/';

      function getGiscusTheme() {
        var saved = localStorage.getItem('theme');
        var isDark = saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (isLocal) return isDark ? 'dark' : 'light';
        return isDark ? themeBase + 'giscus-dark.css' : themeBase + 'giscus-light.css';
      }

      var script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', 'zacharypaynethompson/blog');
      script.setAttribute('data-repo-id', 'R_kgDORmJqPA');
      script.setAttribute('data-category', 'Announcements');
      script.setAttribute('data-category-id', 'DIC_kwDORmJqPM4C5kLH');
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-strict', '1');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', 'bottom');
      script.setAttribute('data-theme', getGiscusTheme());
      script.setAttribute('data-lang', 'en');
      script.setAttribute('crossorigin', 'anonymous');
      script.async = true;

      var container = document.querySelector('.giscus-container');
      if (container) container.appendChild(script);
    })();
  </script>
</section>
