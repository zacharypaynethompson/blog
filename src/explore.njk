---
layout: layouts/base.njk
title: explore
permalink: /explore/
---

{% block head %}
<link rel="stylesheet" href="{{ '/assets/css/network-graph.css' | url }}">
{% endblock %}

<div class="explore-page">
  <header class="explore-header">
    <h1>explore</h1>
    <p>discover connections between posts through shared topics</p>
  </header>

  <div class="explore-container">
    {# Network visualization #}
    <div id="network-graph-container" class="network-graph explore-graph" data-theme="brand-dark" role="application" aria-labelledby="graph-title" aria-describedby="graph-desc">

      <!-- Graph viewport -->
      <div class="graph-viewport">
        <svg id="network-graph-svg" role="img" aria-labelledby="graph-title graph-desc">
          <title id="graph-title">Post relationship network</title>
          <desc id="graph-desc">
            Interactive visualization showing connections between blog posts and tags.
            Posts appear as orange circles, tags as rounded rectangles.
            Hover over nodes to see details and connections. Click posts to read them.
          </desc>
        </svg>
      </div>

      <!-- Loading and error only -->
      <div class="graph-status" aria-live="polite" aria-atomic="true">
        <span class="loading-message">Loading...</span>
        <span class="error-message" style="display: none;">
          Failed to load graph data
        </span>
      </div>
    </div>

    {# List view with search controls at top #}
    <aside class="list-view">
      <div class="content-search">
        <div class="search-controls">
          <input
            type="text"
            id="content-search"
            placeholder="Search posts..."
            class="content-search-input"
            autocomplete="off"
            aria-label="Search post content"
          >
        </div>

        <div class="search-status" id="search-status" style="display: none;">
          <!-- Search status will appear here -->
        </div>
      </div>

      <ul class="post-list-compact" id="post-list">
        {% for post in collections.posts %}
        <li data-tags="{{ post.data.tags | join(',') }}" data-id="{{ post.fileSlug }}">
          <span class="post-title">{{ post.data.title }}</span>
          <span class="post-meta-row">
            <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
            <span class="post-meta-divider">|</span>
            <a href="{{ post.url | url }}" class="go-to-post-link">go to post</a>
          </span>
        </li>
        {% endfor %}
      </ul>
    </aside>
  </div>

  {# Visually hidden accessible list alternative (T046) #}
  <section class="visually-hidden" aria-labelledby="post-connections-heading">
    <h2 id="post-connections-heading">Post connections</h2>
    <ul>
      {% for post in collections.posts %}
      <li>
        <strong>{{ post.data.title }}</strong>
        {% if post.data.tags %}
        (tags: {{ post.data.tags | reject("equalto", "posts") | join(", ") }})
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
</div>

{% block scripts %}
<script src="https://d3js.org/d3.v7.min.js"></script>
<script src="{{ '/assets/js/network-graph.js' | url }}"></script>
<script src="{{ '/assets/js/content-search.js' | url }}"></script>
{% endblock %}
