---
layout: layouts/base.njk
title: home
---

<div class="hero-physics" id="hero-physics">
  <canvas></canvas>
</div>

<div class="home">
  <p class="intro">{{ site.description }}</p>

  <section class="post-list">
    <h2>recent posts</h2>
    {% for post in collections.posts %}
    <article class="post-preview">
      <h3><a href="{{ post.url | url }}">{{ post.data.title }}</a></h3>
      <div class="post-meta">
        <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        {% if post.data.tags %}
        <span class="post-tags">
          {% for tag in post.data.tags %}
            {% if tag != "posts" %}
            <a href="{{ '/tags/' | url }}{{ tag }}/" class="tag">{{ tag }}</a>
            {% endif %}
          {% endfor %}
        </span>
        {% endif %}
      </div>
      {% if post.data.description %}
      <p class="post-description">{{ post.data.description }}</p>
      {% endif %}
    </article>
    {% endfor %}
  </section>
</div>

{% block scripts %}
<script src="{{ '/assets/js/hero-physics.js' | url }}" defer></script>
{% endblock %}
